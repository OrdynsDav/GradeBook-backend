NODE_ENV=development
PORT=3000
# По умолчанию бэкенд слушает 0.0.0.0 (доступ с эмулятора по IP ПК). Только localhost: HOST=127.0.0.1
# HOST=127.0.0.1

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gradebook?schema=public

# Opaque auth tokens
AUTH_ACCESS_TTL_MINUTES=15
AUTH_REFRESH_TTL_DAYS=30
AUTH_TOKEN_PEPPER=change_this_token_pepper_min_16_chars

# CORS
CORS_ORIGIN=http://localhost:8081,http://localhost:3000

# Rate limiting (milliseconds / requests)
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=100
AUTH_RATE_LIMIT_TTL_MS=60000
AUTH_RATE_LIMIT_LIMIT=10

# Docs / logging
SWAGGER_ENABLED=true
LOG_LEVEL=info
